# Database (local PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/archangel_demo

# Gemini (replaces Claude Sonnet 4.6 + GPT-4o for demo)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Auth
JWT_SECRET=change_this_to_a_random_secret_in_dev
JWT_EXPIRY_HOURS=8

# App
DEMO_MODE=true
INCIDENT_RADIUS_METERS=500
CALL_CUT_ESCALATION_SECONDS=90
FRONTEND_URL=http://localhost:5173

# Future (leave blank until credentials arrive)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_RECORDINGS_BUCKET=
BEDROCK_MODEL_ID=claude-sonnet-4-6
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
OPENAI_API_KEY=
MAPBOX_PUBLIC_TOKEN=
